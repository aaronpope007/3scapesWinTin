#class {hayt} {open}

#var guild elemental
#nop nop is dont read this line
#map unlink n;
#map unlink w;
si;
#var csea 1;
#remember, go seacask goes to the cask... duh

#alias longdelay {#delay {299} {#send {}};#delay {595} {#send {}};#delay {797} {#send {}};#delay {595} {#send {1055}};#delay {1354} {#send {}};#delay {1640} {#send {}};#delay {1931} {#send {}};#delay {2200} {#send {}};#delay {2469} {#send {}}};

#act {%*twirl%*around%*} {
	#if {$twirl_sent == 1} {#return};
	#var twirl_sent 1;
	#send {ee};
	#delay {2} {#var twirl_sent 0};
};

#act {%1 nudges you.} {
	#if {$nudge_sent == 1} {#return};
	#var nudge_sent 1;
	#delay {5} {#var nudge_sent 0};
	#var person %1;
	#format person {%l} $person;
	#if {$deadman_active == 1} {
		#echo {<128>[DEADMAN] BLOCKED: nudge response - Idle exceeds 15 min limit<088>};
	} {
		follow $person;
		passist always $person;
		salute $person;
		#if {$my[equip] == "on"} n{
			evoke equipollent as off;
			#var my[equip] off;
			say AOE IS TURNED OFF GOOD SIR!
		};
		#elseif {$my[equip] == "off"} {
			evoke equipollent as on;
			#var my[equip] on;
			say AOE IS TURNED ON GOOD SIR!
		};
	};
};

#alias {kidonates} {#var kicount 0;#ticker {kirundonates} {ki;#math {kicount} {$kicount + 1};#if {$kicount >= 90} {#unticker kirundonates}} {10}}

#alias {away} {#delay {890} {#end}}

#act {[PARTY] Timmy: aoe ON} {ee}
#act {[PARTY] Timmy: aoe OFF} {ee}

#alias {blasts} {cb;ab;cb;ab;cb;ab;cb;ab;cb;ab;pav;give all to mass;give all to giant;give all to mutant;give all to einherjer;give all to human}

#act {There is no beast here} {
	#if {$deadman_active == 1} {
		#echo {<128>[DEADMAN] BLOCKED: kill thorn beast - Idle exceeds 15 min limit<088>};
	} {
		kill thorn beast;
	}
};
#act {Phenomenon pokes you} {passist always phenomenon;partyrole wuss;follow phenomenon}

#act {You attack} {evoke age;gouge};
#act {You are now seeking to achieve equipollence.} {#var my[equip] on;p equipollent is ON};
#act {You are no longer seeking to achieve equipollence.} {#var my[equip] off;p equipollent is OFF};
#act {Bag of Major Sending: Ok.} {put bag in vortex};
#act {Gswap was successful.} {evoke autodrain};
#act {turn off equi} {evoke equipollent};
#act {Hayt joins the party.} {partyrole wuss;passist always rictor;follow rictor};
#act {You arrive at the Sea of Chaos.} {#delay {3600} {#bell;tell hayt -=> You can reset sea!}}
#act {Digbicknick dealt the} {#delay {1} {ki}}
#act {Digbicknick rushes into combat} {
	#if {$deadman_active == 1} {
		#echo {<128>[DEADMAN] BLOCKED: merc hp - Idle exceeds 15 min limit<088>};
	} {
		merc hp;
	}
}


#act {%1 raspberries you!} {
  #echo {Rally trigger!!!};
  #bell;
  #format recruit {%l} {%1};
  rally $recruit;
};

#alias {defenseup} {defense slashing;defense crushing;defense ice;defense fire;defense acid;defense shocking;defense mental;defense magical;defense toxic;defense radiation};

