#alias {fdump} {u;w;w;sw;s;s;s;u;u;u;out;e;e;n;n;n;n;n;n;e;e;e;e;e;n;n;n;n;n;n;n;n;w;w;w;w;w;portal;home;leave;hc}
#dalias {tdump} {n;n;n;ne;e;e;d}
#alias {tserinth} {fantasy;portal;w;w;w;w;w;w;w;s;s;s;s;s;s;s;e;charter serinth}
#alias {tdragonisle} {se;se;se;e;s;s;s;s;s;w;s;s;s;s;e;s;s;s;w;w;w;w;w;w;w;s;s;s;s;s;s;s;s;s;s;s;s;w;w;w;s;se;e;s;sw;w;s;s;s;w;w;s;s;enter town;s;s;s;w;w;enter traveler;push 2}
#alias {tbyrontic} {n;n;leave;w;n;n;n;n;n;n;n;n;w;w;n;w;ne;n;nw;w;w;sw;se;e;n;e}
