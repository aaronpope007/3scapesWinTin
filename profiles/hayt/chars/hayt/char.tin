#alias {fgiants} {climb up;s;s;w;w;w;s;s;s;s;s;s;s;s;s;s;se;s;s;se;se;s;s;leave;w;w;sw;w;w;sw;s;leave;w;w;n;w;w;s;w;w;w;w;w;n;n;portal;home;dmg fire};
